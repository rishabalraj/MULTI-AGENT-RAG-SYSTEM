# ============================================================
# Multi-Agent Enterprise Knowledge Assistant - Environment Config
# ============================================================

# --- LLM Provider ---
OPENAI_API_KEY=your-openai-api-key-here
# Alternatively, for local Llama via Ollama:
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# --- Model Settings ---
LLM_MODEL=gpt-4o-mini            # or gpt-4o, llama3, etc.
EMBEDDING_MODEL=text-embedding-3-small
LLM_TEMPERATURE=0.1
MAX_TOKENS=2048

# --- Vector Store ---
# Options: "faiss" (local) or "qdrant" (production)
VECTOR_STORE_TYPE=faiss
FAISS_INDEX_PATH=./data/faiss_index

# Qdrant (if using Qdrant Cloud or local Qdrant)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your-qdrant-api-key   # leave blank for local
QDRANT_COLLECTION=enterprise_docs

# --- Hybrid Search ---
BM25_WEIGHT=0.3          # Weight for BM25 (keyword) results
VECTOR_WEIGHT=0.7        # Weight for vector (semantic) results
TOP_K_RESULTS=10         # Number of chunks to retrieve
RERANK_TOP_K=5           # Number after re-ranking

# --- Document Processing ---
CHUNK_SIZE=512
CHUNK_OVERLAP=64
DATA_DIR=./data/documents

# --- API Server ---
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Database (for conversation memory & feedback) ---
DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# --- Logging ---
LOG_LEVEL=INFO
